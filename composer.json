{
    "name": "lumenpink/indieinabox",
    "description": "Social Personal Website Swiss Knife",
    "type": "project",
    "license": "ISC",
    "authors": [
        {
            "name": "Lumen Lohn",
            "email": "hi@lumen.pink"
        }
    ],
    "minimum-stability": "dev",
    "require-dev": {
        "phpcompatibility/php-compatibility": "^10.0@dev",
        "squizlabs/php_codesniffer": "^3.0@dev",
        "phpstan/phpstan": "2.1.5",
        "pestphp/pest": "3.7.4",
        "mikey179/vfsstream": "^2.0@dev"
    },
    "autoload": {
        "psr-4": {
            "Indieinabox\\": "app/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "test:compiled": "TEST_COMPILED=true pest",
        "test:all": "composer test && composer test:compiled",
        "sniffer": "composer sniffer:php74 && composer sniffer:php80 && composer sniffer:php81 && composer sniffer:php82 && composer sniffer:php83 && composer sniffer:php84",
        "sniffer:php74": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 7.4",
        "sniffer:php80": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.0",
        "sniffer:php81": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.1",
        "sniffer:php82": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.2",
        "sniffer:php83": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.3",
        "sniffer:php84": "phpcs -p ./app ./bootstrap ./build.php --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility --runtime-set testVersion 8.4"
    }
}
