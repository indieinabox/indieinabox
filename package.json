{
  "name": "indieinabox",
  "version": "0.0.1",
  "description": "Indieweb in a Box",
  "keywords": [
    "Indieweb",
    "PHP"
  ],
  "homepage": "https://github.com/lumenpink/passage#readme",
  "bugs": {
    "url": "https://github.com/lumenpink/passage/issues"
  },
  "repository": {
